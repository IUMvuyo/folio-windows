{
  "name": "folio-windows",
  "version": "1.0.0",
  "description": "Folio — Private Edition. Every PDF tool, 100% on your device. No network, ever.",
  "author": {
    "name": "Quantyx",
    "email": "zimasilevuyo@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:dir": "electron-builder --win --x64 --dir",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "docx": "9.7.1",
    "exceljs": "4.4.0",
    "mammoth": "1.12.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "4.10.38",
    "pptxgenjs": "4.0.1",
    "tesseract.js": "5.1.1"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.zimasilevuyo.folio",
    "productName": "Folio",
    "copyright": "Copyright © 2026 Quantyx",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "assets/lang/**/*",
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "shortcutName": "Folio"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
